{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "esModuleInterop": true,
    "strict": true,
    "noEmit": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true
  },
  "include": ["scripts/**/*", "configs/**/*", "models/**/*"]
}
