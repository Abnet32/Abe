{
  "compilerOptions": {
    "target": "ES2020", // Modern JS target, supports top-level await
    "module": "ESNext", // ESM modules
    "moduleResolution": "node", // Resolves .js imports to .ts during compilation
    "rootDir": "./", // Your source folder
    "outDir": "../dist", // Compiled JS goes here
    "esModuleInterop": true, // Allows default import from CommonJS modules
    "allowJs": true, // Allow importing .js files in TS
    "checkJs": false, // Don’t type-check .js files
    "skipLibCheck": true, // Skip type checking of libraries
    "resolveJsonModule": true, // Allows importing JSON files
    "strict": false // Turn off strict mode (optional, can enable later)
  },
  "include": ["**/*.ts"], // Include all TS files in compilation
  "exclude": ["../dist"] // Exclude the output folder
}
